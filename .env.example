# ═══════════════════════════════════════════════════════
# Multi-Agent Research Engine — Environment Variables
# Copy this file to .env.local and fill in your API keys
# ═══════════════════════════════════════════════════════

# ── Required: OpenAI (for LLM calls) ─────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini         # or gpt-4o, gpt-4-turbo

# ── Optional: Tavily (for real web search) ────────────────
# Get your key at: https://tavily.com
# Without this, the system uses mock search results
TAVILY_API_KEY=tvly-your-tavily-key-here

# ── Optional: Pinecone (for vector memory) ────────────────
# Get your key at: https://pinecone.io
# Without this, the system uses in-memory storage
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=research-engine
# Create a Pinecone index with dimension=1536, metric=cosine

# ── Optional: Anthropic (alternative LLM) ────────────────
# If you prefer Claude over GPT
# ANTHROPIC_API_KEY=sk-ant-your-key-here
